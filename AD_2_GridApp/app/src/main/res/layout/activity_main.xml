<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:text="Home Page"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="3">

        <Button android:text="Profile" android:layout_width="150dp" android:layout_height="100dp" android:layout_margin="8dp" android:gravity="center"/>
        <Button android:text="More Info" android:layout_width="150dp" android:layout_height="100dp" android:layout_margin="8dp" android:gravity="center"/>
        <Button android:text="Register" android:layout_width="150dp" android:layout_height="100dp" android:layout_margin="8dp" android:gravity="center"/>
        <Button android:text="About" android:layout_width="150dp" android:layout_height="100dp" android:layout_margin="8dp" android:gravity="center"/>
        <Button android:text="Contact Us" android:layout_width="150dp" android:layout_height="100dp" android:layout_margin="8dp" android:gravity="center"/>
        <Button android:text="Settings" android:layout_width="150dp" android:layout_height="100dp" android:layout_margin="8dp" android:gravity="center"/>

    </GridLayout>

</LinearLayout>